{
  "name": "学术论文写作",
  "description": "学术论文写作模板，支持摘要、引言、方法、结果、讨论等标准结构",
  "version": "1.0.0",
  "type": "academic",
  "fields": {
    "title": {
      "type": "text",
      "label": "论文标题",
      "required": true,
      "placeholder": "请输入论文标题"
    },
    "abstract": {
      "type": "textarea",
      "label": "摘要",
      "required": true,
      "maxLength": 300,
      "placeholder": "200-300 字摘要"
    },
    "keywords": {
      "type": "tags",
      "label": "关键词",
      "required": true,
      "maxCount": 5,
      "placeholder": "3-5 个关键词"
    },
    "domain": {
      "type": "select",
      "label": "学科领域",
      "required": true,
      "options": [
        "计算机科学",
        "人工智能",
        "数据科学",
        "工程学",
        "医学",
        "社会科学",
        "其他"
      ]
    },
    "wordCount": {
      "type": "number",
      "label": "目标字数",
      "required": false,
      "default": 5000,
      "min": 1000,
      "max": 10000
    },
    "citationStyle": {
      "type": "select",
      "label": "引用格式",
      "required": false,
      "options": [
        "APA",
        "MLA",
        "Chicago",
        "IEEE",
        "其他"
      ]
    }
  },
  "structure": [
    {
      "section": "摘要",
      "required": true,
      "wordCount": 300,
      "description": "简要概括研究目的、方法、结果和结论"
    },
    {
      "section": "引言",
      "required": true,
      "wordCount": 800,
      "description": "介绍研究背景、问题陈述、研究意义"
    },
    {
      "section": "相关工作",
      "required": true,
      "wordCount": 1000,
      "description": "综述相关领域的研究现状"
    },
    {
      "section": "方法",
      "required": true,
      "wordCount": 1500,
      "description": "详细描述研究方法、实验设计、数据来源"
    },
    {
      "section": "结果",
      "required": true,
      "wordCount": 1000,
      "description": "呈现实验结果、数据分析"
    },
    {
      "section": "讨论",
      "required": true,
      "wordCount": 800,
      "description": "解释结果、对比相关研究、讨论局限性"
    },
    {
      "section": "结论",
      "required": true,
      "wordCount": 400,
      "description": "总结主要发现、未来研究方向"
    },
    {
      "section": "参考文献",
      "required": true,
      "wordCount": 0,
      "description": "列出所有引用的文献"
    }
  ],
  "agents": [
    {
      "role": "学术顾问",
      "description": "确保论文结构完整、逻辑严谨",
      "skills": ["学术写作", "逻辑分析", "领域知识"]
    },
    {
      "role": "文献综述师",
      "description": "搜集整理相关文献，确保引用完整",
      "skills": ["文献检索", "信息整理", "引用规范"]
    },
    {
      "role": "数据分析师",
      "description": "分析实验数据，生成图表",
      "skills": ["数据分析", "统计方法", "可视化"]
    },
    {
      "role": "文字编辑",
      "description": "润色文字，确保语言流畅",
      "skills": ["文字润色", "语法检查", "格式规范"]
    },
    {
      "role": "审查专家",
      "description": "全面审查论文质量",
      "skills": ["同行评审", "质量把控", "学术规范"]
    }
  ],
  "checklist": [
    "摘要是否清晰概括全文？",
    "引言是否明确研究问题？",
    "方法描述是否详细可重复？",
    "结果是否有数据支持？",
    "讨论是否深入分析？",
    "结论是否回应研究问题？",
    "参考文献格式是否正确？",
    "全文逻辑是否连贯？"
  ]
}
